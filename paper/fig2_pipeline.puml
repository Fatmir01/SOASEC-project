@startuml fig2_pipeline

' ============================================================
'  Publication-quality pipeline diagram
'  Matches: matplotlib fig2_pipeline.py + LaTeX §3 description
' ============================================================

top to bottom direction
scale 1.0

' ---------- global skin ----------
skinparam defaultFontName        "Serif"
skinparam defaultFontSize        11
skinparam shadowing               false
skinparam RoundCorner             10
skinparam ArrowColor              #444441
skinparam ArrowThickness          1.4
skinparam ArrowFontSize           9
skinparam ArrowFontColor          #666666
skinparam ArrowFontStyle          italic

skinparam rectangle {
  FontSize          11
  StereotypeFontSize 0
}

skinparam package {
  BackgroundColor   transparent
  BorderColor       #854F0B
  BorderThickness   1.2
  FontSize          12
  FontStyle         bold
  FontColor         #854F0B
}

' ---------- stereotype styles ----------
skinparam rectangle<<teal>> {
  BackgroundColor #E1F5EE
  BorderColor     #0F6E56
  FontColor       #0F6E56
}
skinparam rectangle<<purple>> {
  BackgroundColor #EEEDFE
  BorderColor     #3C3489
  FontColor       #3C3489
}
skinparam rectangle<<coral>> {
  BackgroundColor #FAECE7
  BorderColor     #993C1D
  FontColor       #993C1D
}
skinparam rectangle<<gray>> {
  BackgroundColor #F1EFE8
  BorderColor     #444441
  FontColor       #444441
}
skinparam rectangle<<blue>> {
  BackgroundColor #E6F1FB
  BorderColor     #0C447C
  FontColor       #0C447C
}
skinparam rectangle<<amber>> {
  BackgroundColor #FAEEDA
  BorderColor     #854F0B
  FontColor       #854F0B
}
skinparam rectangle<<pink>> {
  BackgroundColor #FBEAF0
  BorderColor     #72243E
  FontColor       #72243E
}

' ============================================================
'  ROW 1 — SHARED PREPROCESSING (teal)
' ============================================================

rectangle "**PDF input**\n//regulation + 4 CEB docs//" <<teal>> as R1_PDF
rectangle "**Markdown**\n//Marker + regex clean//" <<teal>> as R1_MD
rectangle "**Segmentation**\n//5 thematic parts//" <<teal>> as R1_SEG

R1_PDF -right-> R1_MD
R1_MD  -right-> R1_SEG

' ============================================================
'  ROW 2 — TWO PARALLEL BRANCHES
' ============================================================

' --- Legends branch (upper) ---
rectangle "**Legends generation**\n//3 LLMs × 5 pillars//" <<purple>> as LEG_GEN
rectangle "**Classification**\n//6-class pillar//" <<gray>> as LEG_CLS
rectangle "**Span extract**\n//2-stage//" <<gray>> as LEG_SPAN
rectangle "**Q&A generation**\n//factoid + non-factoid//" <<gray>> as LEG_QA
rectangle "**JSONL**\n//327 lines//" <<purple>> as LEG_JS

' --- Regulation branch (lower) ---
rectangle "**Regulation text**\n//cleaned passages//" <<coral>> as REG_SRC
rectangle "**Classification**\n//6-class pillar//" <<gray>> as REG_CLS
rectangle "**Span extract**\n//2-stage//" <<gray>> as REG_SPAN
rectangle "**Q&A generation**\n//factoid + non-factoid//" <<gray>> as REG_QA
rectangle "**JSONL**\n//293 lines//" <<coral>> as REG_JS

' --- Layout: force legends above regulation ---
LEG_GEN -[hidden]down- REG_SRC
LEG_CLS -[hidden]down- REG_CLS
LEG_SPAN -[hidden]down- REG_SPAN
LEG_QA -[hidden]down- REG_QA
LEG_JS -[hidden]down- REG_JS

' --- Fork from Segmentation ---
R1_SEG -down-> LEG_GEN  #3C3489 : //legends//
R1_SEG -down-> REG_SRC  #993C1D : //regulation//

' --- Legends chain ---
LEG_GEN  -right-> LEG_CLS  #3C3489
LEG_CLS  -right-> LEG_SPAN #3C3489
LEG_SPAN -right-> LEG_QA   #3C3489
LEG_QA   -right-> LEG_JS   #3C3489

' --- Regulation chain ---
REG_SRC  -right-> REG_CLS  #993C1D
REG_CLS  -right-> REG_SPAN #993C1D
REG_SPAN -right-> REG_QA   #993C1D
REG_QA   -right-> REG_JS   #993C1D

' ============================================================
'  CONVERGENCE — FINE-TUNING (blue)
' ============================================================

rectangle "**FT**\n//FineTuneDB Studio//\n//gpt-4o//" <<blue>> as FT

LEG_JS -down-> FT #3C3489 : //closed-book\nJSON → JSONL//
REG_JS -down-> FT #993C1D

' ============================================================
'  THREE MODELS (blue)
' ============================================================

rectangle "**Three models:**  base  ·  tuned-legends  ·  tuned-regulation" <<blue>> as MODELS

FT -down-> MODELS #0C447C

' ============================================================
'  EVALUATION + EXPLAINABILITY
' ============================================================

rectangle "**GE-CLS**" <<amber>> as T1
rectangle "**GE-NLI**" <<amber>> as T2
rectangle "**GE-QA**" <<amber>> as T3
rectangle "**GE-WSC**" <<amber>> as T4
rectangle "**GE-NEXT**" <<amber>> as T5

rectangle "**Counterfactual\nInput Probing (CIP)**" <<pink>> as CIP

' --- Force horizontal alignment of eval tasks ---
T1 -[hidden]right- T2
T2 -[hidden]right- T3
T3 -[hidden]right- T4
T4 -[hidden]right- T5
T5 -[hidden]right- CIP

' --- Arrows from models ---
MODELS -down-> T1  #854F0B
MODELS -down-> T2  #854F0B
MODELS -down-> T3  #854F0B
MODELS -down-> T4  #854F0B
MODELS -down-> T5  #854F0B
MODELS -down-> CIP #72243E

' --- GenderEqGLUE grouping ---
package "GenderEqGLUE evaluation" {
  T1
  T2
  T3
  T4
  T5
}

' ============================================================
'  LEGEND
' ============================================================

legend bottom
  |= Color |= Stage |
  |<back:#E1F5EE> &nbsp;&nbsp;&nbsp; </back>| Shared preprocessing |
  |<back:#EEEDFE> &nbsp;&nbsp;&nbsp; </back>| Legends branch |
  |<back:#FAECE7> &nbsp;&nbsp;&nbsp; </back>| Regulation branch |
  |<back:#F1EFE8> &nbsp;&nbsp;&nbsp; </back>| Shared stages (both branches) |
  |<back:#E6F1FB> &nbsp;&nbsp;&nbsp; </back>| Fine-tuning / models |
  |<back:#FAEEDA> &nbsp;&nbsp;&nbsp; </back>| Evaluation (GenderEqGLUE) |
  |<back:#FBEAF0> &nbsp;&nbsp;&nbsp; </back>| Explainability (CIP) |
end legend

@enduml
